{
  "productName": "Notes",
  "version": "0.4.0",
  "identifier": "com.stickynotes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build & exit /b 0"
  },
  "app": {
    "windows": [
      {
        "title": "Sticky Notes",
        "width": 300,
        "height": 400,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "center": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "copyright": "kardelitaitu",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
